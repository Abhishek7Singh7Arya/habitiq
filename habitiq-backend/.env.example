# Postgres configuration
POSTGRES_USER=habitiq
POSTGRES_PASSWORD=habitiq_secret

# AI Providers (At least one must be set. Gemini is the default)
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VOICE_FROM=your_twilio_phone_number
TWILIO_WEBHOOK_BASE_URL=http://your_public_ngrok_or_dns_url
